# ---------------------------------------------------------------------------
# CANIAS ERP veritabani baglanti ayarlari (Microsoft SQL Server)
# ---------------------------------------------------------------------------
# Bu dosyayi .env olarak kopyalayin ve CANIAS_DB_PASSWORD degerini doldurun.
#
# ADO.NET karsiligi:
#   Data Source=DEBAKNETSIS\DB20;Initial Catalog=DBKBGYS;User ID=sa;Password=***

CANIAS_DB_DRIVER=ODBC Driver 18 for SQL Server
CANIAS_DB_SERVER=DEBAKNETSIS\DB20
CANIAS_DB_NAME=DBKBGYS
CANIAS_DB_USER=sa
CANIAS_DB_PASSWORD=your_db_password
CANIAS_DB_TRUST_CERT=yes
CANIAS_DB_ENCRYPT=no

# CANIAS sistem parametreleri (trace: CLIENT=00, COMPANY=01, LANGU=T)
CANIAS_CLIENT=00
CANIAS_LANGU=T
CANIAS_DEFAULT_COMPANY=01
CANIAS_DEFAULT_PLANT=01
CANIAS_SENDIKA=0

# Uygulama
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=false
