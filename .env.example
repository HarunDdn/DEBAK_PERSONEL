# CANIAS ERP veritabanı bağlantısı
# Desteklenen sürücüler: mssql (SQL Server), oracle
DB_DRIVER=mssql
DB_HOST=localhost
DB_PORT=1433
DB_NAME=CANIAS
DB_USER=readonly_user
DB_PASSWORD=your_password

# CANIAS sistem parametreleri (log dosyasından: CLIENT=00, COMPANY=01, LANGU=T)
CANIAS_CLIENT=00
CANIAS_COMPANY=01
CANIAS_LANGUAGE=T

# Uygulama
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=false
